/**
 * Conditional visual loader. Three.js is used only by the ambient background,
 * so it is skipped on compact/data-saver/low-memory/reduced-motion devices and
 * deferred on desktop until the visitor interacts. Core content never depends
 * on this enhancement.
 */
(function () {
  'use strict';

  var saveData = navigator.connection && navigator.connection.saveData;
  var lowMemory = navigator.deviceMemory && navigator.deviceMemory <= 2;
  var compact = window.matchMedia && window.matchMedia('(max-width: 759px)').matches;
  var reduced = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  var canvas = document.getElementById('glCanvas');

  if (saveData || lowMemory || compact || reduced) {
    document.body.classList.add('mobile-lite');
    if (canvas) canvas.style.display = 'none';
    return;
  }

  function load(src, done) {
    var script = document.createElement('script');
    script.src = src;
    script.async = true;
    script.onload = done || null;
    script.onerror = function () {
      if (canvas) canvas.style.display = 'none';
    };
    document.head.appendChild(script);
  }

  var started = false;
  function start() {
    if (started) return;
    started = true;
    window.removeEventListener('pointermove', start);
    window.removeEventListener('scroll', start);
    window.removeEventListener('keydown', start);
    load('assets/js/vendor/three.min.js', function () {
      load('assets/js/background.min.js');
    });
  }

  window.addEventListener('pointermove', start, { passive: true, once: true });
  window.addEventListener('scroll', start, { passive: true, once: true });
  window.addEventListener('keydown', start, { once: true });

  // Still enable the enhancement for a completely idle desktop visit, but
  // keep it out of the initial rendering/network critical path.
  setTimeout(start, 12000);
})();
