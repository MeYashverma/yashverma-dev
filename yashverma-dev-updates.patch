-.menu-overlay__socials a, .menu-overlay__meta {
-  font-family: var(--font-mono); font-size: 12px; color: var(--text-dim); letter-spacing: .03em;
-}
-
-/* ============================================================
-   Layout helpers
-   ============================================================ */
-main { position: relative; z-index: 1; }
