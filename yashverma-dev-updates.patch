+  counter-reset: notes;
+}
+.note-card {
+  position: relative; display: flex; min-height: 262px; flex-direction: column;
+  padding: clamp(21px, 2.8vw, 32px); overflow: hidden;
+  border: 1px solid var(--line); border-radius: 15px;
+  background: linear-gradient(135deg, rgba(255,255,255,.028), transparent 55%), var(--panel);
+  transition: border-color .3s var(--ease-out), transform .35s var(--ease-out), background .3s var(--ease-out);
+}
+.note-card::before {
+  content: ''; position: absolute; inset: 0; pointer-events: none; opacity: 0;
+  background: radial-gradient(70% 90% at 100% 0%, rgba(217,255,63,.1), transparent 68%);
+  transition: opacity .35s var(--ease-out);
+}
+.note-card:hover { transform: translateY(-4px); border-color: rgba(217,255,63,.3); background-color: var(--panel-raised); }
+.note-card:hover::before { opacity: 1; }
+.note-card > * { position: relative; z-index: 1; }
+.note-card__top {
+  display: flex; justify-content: space-between; gap: 16px; margin-bottom: auto;
+  color: var(--text-faint); font-family: var(--font-mono); font-size: 9px; letter-spacing: .13em;
+}
+.note-card__top span:last-child { color: var(--accent-dim); }
+.note-card h3 {
+  max-width: 16ch; margin: 32px 0 12px; color: var(--text);
+  font-family: var(--font-display); font-size: clamp(21px, 2vw, 29px); font-weight: 550;
+  letter-spacing: -.025em; line-height: 1.06;
+}
+.note-card p { max-width: 56ch; color: var(--text-dim); font-size: 13px; line-height: 1.65; }
+.note-card__link {
+  display: inline-flex; align-items: center; gap: 8px; width: fit-content; margin-top: 24px;
+  color: var(--text); font-family: var(--font-mono); font-size: 10px; letter-spacing: .04em;
+}
+.note-card__link span { color: var(--accent); font-size: 14px; transition: transform .25s var(--ease-out); }
+.note-card__link:hover { color: var(--accent); }
+.note-card__link:hover span { transform: translateX(3px); }
+@media (max-width: 760px) {
+  .notes__head { grid-template-columns: 1fr; align-items: start; gap: 20px; }
+  .notes__grid { grid-template-columns: 1fr; }
+  .note-card { min-height: 236px; }
