+}
+.notes__eyebrow {
+  display: block; margin-bottom: 15px; color: var(--accent);
+  font-family: var(--font-mono); font-size: 10px; letter-spacing: .16em; text-transform: uppercase;
+}
+.notes__title {
+  font-family: var(--font-display); font-size: clamp(42px, 6.2vw, 76px);
