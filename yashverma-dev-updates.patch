-  background: #fff; transition: width .3s var(--ease-out);
-}
-.nav__links a:hover::after { width: 100%; }
-.nav__clock {
-  font-family: var(--font-mono); font-size: 12px; color: rgba(255,255,255,0.5);
-  letter-spacing: .04em;
-}
-.nav__menu-btn {
-  display: none; width: 32px; height: 20px; position: relative; z-index: 600;
-}
-.nav__menu-btn span {
-  position: absolute; left: 0; width: 100%; height: 1.5px; background: #fff;
-  transition: transform .3s var(--ease-out), opacity .3s;
-}
-.nav__menu-btn span:first-child { top: 0; }
-.nav__menu-btn span:last-child { bottom: 0; }
