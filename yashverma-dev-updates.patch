-          el.style.transform = 'translate(' + (relX * strength) + 'px,' + (relY * strength) + 'px)';
-        }
-      });
-
-      el.addEventListener('mouseleave', function () {
-        if (hasGSAP) {
-          gsap.to(el, { x: 0, y: 0, duration: 0.6, ease: 'elastic.out(1, 0.4)' });
-        } else {
